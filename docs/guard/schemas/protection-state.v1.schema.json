{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hol.org/schemas/guard/protection-state.v1.schema.json",
  "title": "HOL Guard protection state projection v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workspaceId", "deviceId", "installationGeneration", "state", "reasonCodes", "assuranceLevel", "leaseFreshUntil", "observerFreshUntil", "remediationState", "lastTransitionAt", "evidenceDigests"],
  "properties": {
    "schemaVersion": {"const": "protection-state.v1"},
    "workspaceId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "deviceId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "installationGeneration": {"oneOf": [{"$ref": "self-protection-common.v1.schema.json#/$defs/hex32"}, {"type": "null"}]},
    "state": {"$ref": "self-protection-common.v1.schema.json#/$defs/protectionState"},
    "reasonCodes": {"type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": {"$ref": "self-protection-common.v1.schema.json#/$defs/reasonCode"}},
    "assuranceLevel": {"$ref": "self-protection-common.v1.schema.json#/$defs/assuranceLevel"},
    "leaseFreshUntil": {"oneOf": [{"$ref": "self-protection-common.v1.schema.json#/$defs/timestamp"}, {"type": "null"}]},
    "observerFreshUntil": {"oneOf": [{"$ref": "self-protection-common.v1.schema.json#/$defs/timestamp"}, {"type": "null"}]},
    "remediationState": {"enum": ["none", "requested", "accepted", "running", "succeeded", "failed", "paused"]},
    "lastTransitionAt": {"$ref": "self-protection-common.v1.schema.json#/$defs/timestamp"},
    "evidenceDigests": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"$ref": "self-protection-common.v1.schema.json#/$defs/hex64"}}
  }
}
