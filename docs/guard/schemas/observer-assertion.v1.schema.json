{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hol.org/schemas/guard/observer-assertion.v1.schema.json",
  "title": "HOL Guard observer assertion v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "assertionId", "workspaceId", "observerId", "adapterId", "externalDeviceId", "observedAt", "expiresAt", "detection", "remediation", "signature"],
  "properties": {
    "schemaVersion": {"const": "observer-assertion.v1"},
    "assertionId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "workspaceId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "observerId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "adapterId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "externalDeviceId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "observedAt": {"$ref": "self-protection-common.v1.schema.json#/$defs/timestamp"},
    "expiresAt": {"$ref": "self-protection-common.v1.schema.json#/$defs/timestamp"},
    "detection": {
      "type": "object", "additionalProperties": false,
      "required": ["state", "endpointOnline", "version", "packageIdentity", "reasonCodes"],
      "properties": {
        "state": {"$ref": "self-protection-common.v1.schema.json#/$defs/detectionState"},
        "endpointOnline": {"type": ["boolean", "null"]},
        "version": {"type": ["string", "null"], "maxLength": 128},
        "packageIdentity": {"type": ["string", "null"], "maxLength": 256},
        "reasonCodes": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"$ref": "self-protection-common.v1.schema.json#/$defs/observerReasonCode"}}
      }
    },
    "remediation": {
      "type": "object", "additionalProperties": false, "required": ["state", "jobId"],
      "properties": {
        "state": {"enum": ["none", "queued", "accepted", "running", "succeeded", "failed", "paused", "unknown"]},
        "jobId": {"oneOf": [{"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"}, {"type": "null"}]}
      }
    },
    "signature": {"$ref": "self-protection-common.v1.schema.json#/$defs/signature"}
  }
}
