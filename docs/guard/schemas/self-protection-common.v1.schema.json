{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hol.org/schemas/guard/self-protection-common.v1.schema.json",
  "title": "HOL Guard self-protection common definitions v1",
  "$defs": {
    "safeId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "hex32": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "hex64": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "boundedReason": {"type": "string", "minLength": 1, "maxLength": 512},
    "assuranceLevel": {"enum": ["user-managed", "mdm-managed-unverified", "mdm-managed"]},
    "keyProtectionLevel": {"enum": ["hardware-backed", "os-protected", "file-backed", "unavailable", "unknown"]},
    "detectionState": {"enum": ["present", "absent", "partial", "unknown", "unsupported"]},
    "protectionState": {
      "enum": [
        "healthy", "degraded", "late", "offline", "unknown", "suspected_absent", "tampered",
        "unexpectedly_absent", "removal_pending", "removed_authorized", "repairing", "recovered", "retired"
      ]
    },
    "reasonCode": {
      "enum": [
        "lease_current", "lease_expired_in_grace", "lease_expired", "lease_replayed", "lease_out_of_order",
        "lease_wrong_generation", "lease_wrong_identity", "lease_invalid_signature", "lease_future_dated", "lease_oversized",
        "observer_current_present", "observer_current_absent", "observer_current_partial", "observer_offline", "observer_stale",
        "observer_mapping_ambiguous", "observer_credential_invalid", "removal_authorized", "removal_authorization_expired",
        "removal_completed_confirmed", "repair_requested", "repair_in_progress", "recovery_threshold_met", "device_retired",
        "maintenance_window_active", "suppression_active", "observer_required", "legacy_unattested",
        "local_integrity_degraded", "local_integrity_tampered"
      ]
    },
    "observerReasonCode": {
      "enum": [
        "observer_current_present",
        "observer_current_absent",
        "observer_current_partial",
        "observer_offline",
        "observer_stale",
        "observer_mapping_ambiguous",
        "observer_credential_invalid"
      ]
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "keyId", "value"],
      "properties": {
        "algorithm": {"enum": ["ecdsa-p256-sha256", "ed25519"]},
        "keyId": {"$ref": "#/$defs/safeId"},
        "value": {"type": "string", "minLength": 1, "maxLength": 512, "contentEncoding": "base64"}
      }
    }
  }
}
