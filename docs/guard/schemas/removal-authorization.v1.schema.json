{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hol.org/schemas/guard/removal-authorization.v1.schema.json",
  "title": "HOL Guard removal authorization v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "authorizationId", "workspaceId", "deviceId", "installationGeneration", "operation", "actorId", "reason", "issuedAt", "expiresAt", "nonce", "signature"],
  "properties": {
    "schemaVersion": {"const": "removal-authorization.v1"},
    "authorizationId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "workspaceId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "deviceId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "installationGeneration": {"$ref": "self-protection-common.v1.schema.json#/$defs/hex32"},
    "operation": {"enum": ["deactivate", "uninstall"]},
    "actorId": {"$ref": "self-protection-common.v1.schema.json#/$defs/safeId"},
    "reason": {"$ref": "self-protection-common.v1.schema.json#/$defs/boundedReason"},
    "issuedAt": {"$ref": "self-protection-common.v1.schema.json#/$defs/timestamp"},
    "expiresAt": {"$ref": "self-protection-common.v1.schema.json#/$defs/timestamp"},
    "nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]{32,128}$"},
    "signature": {"$ref": "self-protection-common.v1.schema.json#/$defs/signature"}
  }
}
